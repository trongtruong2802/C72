<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard_surface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        app:subtitleTextColor="@color/dashboard_muted"
        app:titleTextColor="@color/dashboard_ink" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="8dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_assettrack_mark" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_asset"
                        android:textColor="#1F65B0"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_track"
                        android:textColor="#59C13F"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDashboardHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="#14FFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dashboard_hero"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_hero_title"
                        android:textColor="@android:color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDashboardStateChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_dashboard_chip_loading"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="@string/dashboard_status_loading"
                        android:textColor="@color/dashboard_chip_loading_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDashboardMasterStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/dashboard_status_message_empty"
                        android:textColor="@android:color/white"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvDashboardPreviewCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/dashboard_preview_idle"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDashboardSyncPercentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="#59C13F"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressDashboardSync"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        app:indicatorColor="#59C13F"
                        app:trackColor="#40FFFFFF"
                        app:trackThickness="6dp"
                        app:trackCornerRadius="3dp" />

                    <TextView
                        android:id="@+id/tvDashboardSyncProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/dashboard_progress_idle"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:cardBackgroundColor="#17FFFFFF"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#24FFFFFF"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:contentDescription="@string/dashboard_filter_section_title"
                                    android:src="@drawable/ic_assets_filter"
                                    app:tint="@android:color/white" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:layout_marginEnd="8dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/dashboard_filter_section_title"
                                        android:textColor="@android:color/white"
                                        android:maxLines="1"
                                        android:ellipsize="end"
                                        android:textSize="15sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/buttonDashboardClearFilters"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:minHeight="0dp"
                                    android:paddingStart="12dp"
                                    android:paddingTop="8dp"
                                    android:paddingEnd="12dp"
                                    android:paddingBottom="8dp"
                                    android:text="@string/dashboard_action_clear_filters"
                                    android:textAllCaps="false"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    app:icon="@android:drawable/ic_menu_close_clear_cancel"
                                    app:iconGravity="textStart"
                                    app:iconPadding="6dp"
                                    app:iconTint="@android:color/white"
                                    app:rippleColor="#22FFFFFF"
                                    app:strokeColor="@android:color/white"
                                    app:strokeWidth="1dp" />
                            </LinearLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutDashboardDepartmentFilter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:hint="@string/dashboard_filter_department"
                                app:boxBackgroundColor="@android:color/white"
                                app:boxBackgroundMode="filled"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp"
                                app:hintTextColor="#333333"
                                app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
                                app:startIconTint="@color/dashboard_primary_dark"
                                app:endIconMode="custom"
                                app:endIconDrawable="@android:drawable/ic_menu_close_clear_cancel"
                                app:endIconTint="@color/dashboard_muted">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/actDashboardDepartmentFilter"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:dropDownHeight="320dp"
                                    android:dropDownVerticalOffset="8dp"
                                    android:inputType="none"
                                    android:maxLines="1"
                                    android:textColor="#111111"
                                    android:textColorHint="#555555" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutDashboardLocationFilter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:hint="@string/dashboard_filter_location"
                                app:boxBackgroundColor="@android:color/white"
                                app:boxBackgroundMode="filled"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp"
                                app:hintTextColor="#333333"
                                app:startIconDrawable="@android:drawable/ic_menu_mylocation"
                                app:startIconTint="@color/dashboard_primary_dark"
                                app:endIconMode="custom"
                                app:endIconDrawable="@android:drawable/ic_menu_close_clear_cancel"
                                app:endIconTint="@color/dashboard_muted">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/etDashboardLocationFilter"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:dropDownHeight="320dp"
                                    android:dropDownVerticalOffset="8dp"
                                    android:inputType="none"
                                    android:maxLines="1"
                                    android:textColor="#111111"
                                    android:textColorHint="#555555" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutDashboardAssetTypeFilter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:hint="@string/dashboard_filter_asset_type"
                                app:boxBackgroundColor="@android:color/white"
                                app:boxBackgroundMode="filled"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp"
                                app:hintTextColor="#333333"
                                app:startIconDrawable="@android:drawable/ic_menu_agenda"
                                app:startIconTint="@color/dashboard_primary_dark"
                                app:endIconMode="custom"
                                app:endIconDrawable="@android:drawable/ic_menu_close_clear_cancel"
                                app:endIconTint="@color/dashboard_muted">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/etDashboardAssetTypeFilter"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:dropDownHeight="320dp"
                                    android:dropDownVerticalOffset="8dp"
                                    android:inputType="none"
                                    android:maxLines="1"
                                    android:textColor="#111111"
                                    android:textColorHint="#555555" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="#1AFFFFFF"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#24FFFFFF"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dashboard_asset_count_label"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvDashboardAssetCount"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="0"
                                    android:textColor="@android:color/white"
                                    android:textSize="24sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="#1AFFFFFF"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#24FFFFFF"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dashboard_last_sync_label"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvDashboardLastSync"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/dashboard_sync_never"
                                    android:textColor="@android:color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonDashboardLoadAll"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="1"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:text="@string/dashboard_action_load_all"
                            android:textAllCaps="false"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:autoSizeMaxTextSize="15sp"
                            app:autoSizeMinTextSize="12sp"
                            app:autoSizeStepGranularity="1sp"
                            app:autoSizeTextType="uniform"
                            app:backgroundTint="@android:color/white"
                            app:cornerRadius="18dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonDashboardSyncSession"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="1"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:text="@string/dashboard_action_sync_session_short"
                            android:textAllCaps="false"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:autoSizeMaxTextSize="15sp"
                            app:autoSizeMinTextSize="12sp"
                            app:autoSizeStepGranularity="1sp"
                            app:autoSizeTextType="uniform"
                            app:backgroundTint="#E8F4FF"
                            app:cornerRadius="18dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonDashboardSyncFiltered"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/dashboard_action_sync_filtered"
                        android:textAllCaps="false"
                        android:textColor="#111111"
                        android:textStyle="bold"
                        app:backgroundTint="#D7F0D4"
                        app:cornerRadius="18dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <ViewStub
                android:id="@+id/stubDashboardQuickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:inflatedId="@+id/layoutDashboardQuickActions"
                android:layout="@layout/layout_dashboard_quick_actions" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
