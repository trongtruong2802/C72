<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvDashboardQuickActionsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/dashboard_menu_title"
        android:textColor="@color/dashboard_ink"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonOpenInventory"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/dashboard_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:rippleColor="@color/dashboard_primary_soft"
            app:strokeColor="@color/dashboard_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <View
                    android:layout_width="42dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="@color/dashboard_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="@color/dashboard_inventory_tint"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="@string/dashboard_inventory_badge"
                    android:textColor="@color/dashboard_primary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_inventory_title"
                    android:textColor="@color/dashboard_ink"
                    android:textSize="19sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonOpenCheckOut"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/dashboard_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:rippleColor="@color/dashboard_primary_soft"
            app:strokeColor="@color/dashboard_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <View
                    android:layout_width="42dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="@color/dashboard_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="@color/dashboard_checkout_tint"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="@string/dashboard_checkout_badge"
                    android:textColor="@color/dashboard_primary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_checkout_title"
                    android:textColor="@color/dashboard_ink"
                    android:textSize="19sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonOpenCheckIn"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/dashboard_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:rippleColor="@color/dashboard_primary_soft"
            app:strokeColor="@color/dashboard_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <View
                    android:layout_width="42dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="#4B86C8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="@color/dashboard_checkin_tint"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="@string/dashboard_checkin_badge"
                    android:textColor="@color/dashboard_primary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_checkin_title"
                    android:textColor="@color/dashboard_ink"
                    android:textSize="19sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonOpenHandover"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/dashboard_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:rippleColor="@color/dashboard_primary_soft"
            app:strokeColor="@color/dashboard_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <View
                    android:layout_width="42dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="#9666C8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="@color/dashboard_handover_tint"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="@string/dashboard_handover_badge"
                    android:textColor="@color/dashboard_primary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_handover_title"
                    android:textColor="@color/dashboard_ink"
                    android:textSize="19sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonOpenLookup"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/dashboard_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:rippleColor="@color/dashboard_primary_soft"
            app:strokeColor="@color/dashboard_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <View
                    android:layout_width="42dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="#72A942" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="@color/dashboard_lookup_tint"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="@string/dashboard_lookup_badge"
                    android:textColor="@color/dashboard_primary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_lookup_title"
                    android:textColor="@color/dashboard_ink"
                    android:textSize="19sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonOpenHistory"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/dashboard_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:rippleColor="@color/dashboard_primary_soft"
            app:strokeColor="@color/dashboard_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <View
                    android:layout_width="42dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="#C96B4D" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_dashboard_pill"
                    android:backgroundTint="@color/dashboard_history_tint"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="@string/dashboard_history_badge"
                    android:textColor="@color/dashboard_primary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_history_title"
                    android:textColor="@color/dashboard_ink"
                    android:textSize="19sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
